{
  "name": "@react-native-ama/lists",
  "version": "2.0.0-beta.2",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./DynamicFlatList": {
      "types": "./dist/components/DynamicFlatList.d.ts",
      "default": "./dist/components/DynamicFlatList.js"
    },
    "./FlatList": {
      "types": "./dist/components/FlatList.d.ts",
      "default": "./dist/components/FlatList.js"
    },
    "./StaticFlatList": {
      "types": "./dist/components/StaticFlatList.d.ts",
      "default": "./dist/components/StaticFlatList.js"
    },
    "./useDynamicList": {
      "types": "./dist/hooks/useDynamicList.d.ts",
      "default": "./dist/hooks/useDynamicList.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p ./tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "peerDependencies": {
    "@react-native-ama/core": "~2.0.0-beta.2",
    "expo": ">=47.0.0",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-ama/core": {
      "optional": true
    },
    "expo": {
      "optional": true
    }
  },
  "keywords": [
    "react-native",
    "a11y",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FormidableLabs/react-native-ama",
    "directory": "packages/lists"
  },
  "bugs": {
    "url": "https://github.com/FormidableLabs/react-native-ama/issues"
  },
  "homepage": "https://github.com/FormidableLabs/react-native-ama#readme",
  "publishConfig": {
    "provenance": true
  },
  "author": "",
  "license": "MIT",
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/node_modules",
      "<rootDir>/dist/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 100,
        "branches": 85,
        "functions": 100,
        "lines": 100
      }
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native-reanimated|expo|@expo)/)"
    ],
    "transform": {
      "\\.[jt]sx?$": "babel-jest"
    },
    "moduleDirectories": [
      "node_modules",
      "../../playground/node_modules"
    ],
    "moduleNameMapper": {
      "@react-native/js-polyfills/error-guard": "<rootDir>/../../jest-mocks/error-guard.js",
      "^(\\.{1,2}/)*ama\\.config\\.json$": "<rootDir>/../../jest-mocks/ama-config.js",
      "^(\\.{1,2}/)*ReactNativeAmaModule$": "<rootDir>/../../jest-mocks/ReactNativeAmaModule.js",
      "^(\\.{1,2}/)*ReactNativeAmaView(\\.web)?$": "<rootDir>/../../jest-mocks/ReactNativeAmaModule.js",
      "^@react-native-ama/core$": "<rootDir>/../../jest-mocks/ama-core.js",
      "^@react-native-ama/core/(.*)$": "<rootDir>/../../packages/core/$1"
    },
    "verbose": true
  }
}
